{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    "paths": {
      "@logistic/db": ["packages/db/src"],
      "@logistic/common": ["packages/common/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
