generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id            String   @id @default(uuid())
  mobileNumber  String   @unique
  name          String
  role          String
  createdAt     DateTime @default(now())
}

model Order {
  id                      String            @id @default(uuid())
  orderId                 String
  barcode                 String?
  phase                   String            @default("PICKUP")
  
  sellerId                Int
  seller                  Seller            @relation(fields: [sellerId], references: [id])
  buyerId                 Int
  buyer                   Buyer             @relation(fields: [buyerId], references: [id])
  
  // Package dimensions
  productCount            Int               @default(1)
  totalQty                Int               @default(1)
  totalWeight             Float             @default(0.0)
  
  // SHG & Transporter assignments
  pickupShgId             String?
  pickupTransporterId     String?
  dropShgId               String?
  dropTransporterId       String?
  pickupReturnShgId       String?
  returnTransporterId     String?
  
  // Statuses
  mainStatus              String            // Enum values like PENDING_PICKUP, HUB_RECEIVED, etc.
  pickupShgStatus         String?           // PENDING, ACCEPTED, REJECTED, PICKED
  pickupTransporterStatus String?           // PENDING, TRANSPORTER_ACCEPTED, IN_TRANSIT_TO_HUB
  dropShgStatus           String?           // PENDING, ACCEPTED, REJECTED, DROP_SHG_DELIVERED
  dropTransporterStatus   String?           // PENDING, TRANSPORTER_ACCEPTED, PARCEL_AT_DROP_SHG
  
  // Return & Reschedule indicators
  returnType              String?           // TRANSPORTER_RETURN, BUYER_RETURN
  rescheduleType          String?           // PICKUP_SHG, PICKUP_TRANSPORTER, DROP_SHG, DROP_TRANSPORTER
  rescheduleDuration      String?           // e.g. "2 HOURS", "24 HOURS"
  
  // Timestamps
  warehouseReceivedAt     DateTime?
  barcodeGeneratedAt      DateTime?
  storedAt                DateTime?
  dispatchedAt            DateTime?
  deliveredAt             DateTime?
  rescheduledAt           DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  assignments             OrderAssignment[]

  @@index([orderId])
  @@index([barcode])
}

model OrderAssignment {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assigneeId   String
  assigneeType String   // SHG, TRANSPORTER
  role         String   // PICKUP, DROP, RETURN
  status       String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  SHG
  INDIVIDUAL
  TRANSPORTER
  ADMIN
  SUPER_ADMIN
  BUYER
  SELLER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
  COMPLETED
}

enum VehicleType {
  TWO_WHEELER
  THREE_WHEELER
  FOUR_WHEELER
  MILK_VAN
  OTHER
}

enum ProductCategory {
  FOOD
  HANDMADE
  AGRICULTURE
  TEXTILE
  DAIRY
  OTHER
}

enum StepStatus {
  PENDING
  COMPLETED
}

enum ShgRole {
  CRP
  LEADER
  MEMBER
}

model User {
  id                  Int       @id @default(autoincrement())

  // Supabase Auth ID
  authId              String    @unique @db.Uuid

  role                UserRole
  phoneNumber         String    @unique
  email               String?   @unique

  fullName            String?
  profilePhoto        String?

  language            String?   @default("English")

  isVerified          Boolean   @default(false)

  currentStep         Int       @default(0)
  profileCompletion   Int       @default(0)

  applicationStatus   ApplicationStatus @default(PENDING)

  uniqueCode          String?   @unique

  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  address             Address?
  bankDetails         BankDetail[]
  documents           Document[]
  otherDetails        OtherDetails[]

  shgDetail           ShgDetail?
  businessDetail      BusinessDetail?
  products            Product[]

  transporterDetail   TransporterDetail?
  drivingDetail       DrivingDetail?
  routeDetail         RouteDetail?
  milkVanDetail       MilkVanDetail?

  applications        Application[]
  stepTracking        StepTracking[]
  auditLogs           AuditLog[]

  // New clean architecture relations
  shgPickupOrders     PickupOrder[]       @relation("ShgPickupOrders")
  transporterPickups  PickupOrder[]       @relation("TransporterPickupOrders")
  
  shgDropOrders       DropOrder[]         @relation("ShgDropOrders")
  transporterDrops    DropOrder[]         @relation("TransporterDropOrders")

  @@index([phoneNumber])
  @@index([role])
}

model Address {
  id            Int      @id @default(autoincrement())

  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])

  houseNo       String
  deliveryAddress String?

  village       String?
  taluka        String?
  district      String
  state         String   @default("Maharashtra")
  pincode       String
  postOffice    String?

  landmark      String?

  latitude      Float?
  longitude     Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankDetail {
  id                  Int      @id @default(autoincrement())

  userId              Int
  user                User     @relation(fields: [userId], references: [id])

  accountHolderName   String
  bankName            String
  accountNumber       String
  ifscCode            String

  branchName          String?
  upiId               String?

  isVerified          Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([userId])
}

model Document {
  id                  Int      @id @default(autoincrement())

  userId              Int
  user                User     @relation(fields: [userId], references: [id])

  aadhaarNumber       String?
  panNumber           String?

  aadhaarFrontUrl     String?
  aadhaarBackUrl      String?
  panCardUrl          String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model OtherDetails {
  id                    Int         @id @default(autoincrement())

  userId                Int
  user                  User        @relation(fields: [userId], references: [id])

  vehicleType           VehicleType

  vehicleName           String?
  registrationNumber    String?
  licenseNumber         String?

  rcUrl                 String?
  insuranceUrl          String?
  vehicleImageUrl       String?

  heihgt                Float?
  width                 Float?
  storageSpace          String?
  DLurl                 String?
  wheeler               String?
  minWeight             Float?
  maxWeight             Float?
  ratePerKm             Float?
  carryingCapacity      String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@index([userId])
}

model Application {
  id                  Int                 @id @default(autoincrement())

  userId              Int
  user                User                @relation(fields: [userId], references: [id])

  status              ApplicationStatus   @default(PENDING)

  reviewedBy          String?
  rejectionReason     String?

  approvedAt          DateTime?
  rejectedAt          DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model StepTracking {
  id            Int         @id @default(autoincrement())

  userId        Int
  user          User        @relation(fields: [userId], references: [id])

  step          Int
  status        StepStatus  @default(PENDING)

  data          Json?

  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, step])
  @@index([userId, step])
}

model ShgDetail {
  id                  Int         @id @default(autoincrement())

  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])

  fullName            String?
  shgName             String?
  shgLeaderName       String?
  shgLeaderContact    String?
  memberCode          String?

  shgRole             ShgRole?

  crpName             String?
  crpMobile           String?
  crpEmail            String?

  groupSize           Int?
  imgUrl              String?
  age                 Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BusinessDetail {
  id                  Int         @id @default(autoincrement())

  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])

  producesProduct     Boolean     @default(false)
  businessTeamSize    Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TransporterDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  transporterCode       String?     @unique

  vehicleCategory       VehicleType?

  experienceYears       Int?

  availableFullTime     Boolean     @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DrivingDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  licenseNumber         String
  expiryDate            DateTime

  drivingExperience     Int?
  drivingLicenseNo      String?
  drivingLicenseUrl     String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model RouteDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  operatingArea         String

  pickupLocations       Json?
  dropLocations         Json?

  workingDays           Json?
  workingSchedule       Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MilkVanDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  sangathanName         String
  centerName            String

  assignedVillages      Json?

  morningShiftTime      String?
  eveningShiftTime      String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id              Int      @id @default(autoincrement())

  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])

  module          String
  action          String

  oldData         Json?
  newData         Json?

  ipAddress       String?

  createdAt       DateTime @default(now())

  @@index([userId])
}

model OTPVerification {
  id              Int      @id @default(autoincrement())

  phoneNumber     String

  otp             String
  type            String

  attempts        Int      @default(0)

  expiresAt       DateTime

  createdAt       DateTime @default(now())

  @@index([phoneNumber])
}

model Product {
  id          Int      @id @default(autoincrement())
  sellerId    Int      @map("seller_id")
  seller      User     @relation(fields: [sellerId], references: [id])
  name        String
  category    String?
  price       Float
  stock       Int      @default(0)
  weight      Float?
  image       String?
  dailyProduction  Float?
  Unit             String?
  weeklyProduction Float?
  createdAt   DateTime @default(now()) @map("created_at")

  masterOrderItems   MasterOrderItem[]
  pickupOrderItems   PickupOrderItem[]
  warehouseInventory WarehouseInventory[]
  dropOrderItems     DropOrderItem[]

  @@index([sellerId])
  @@index([category])
  @@map("products")
}

model MasterOrder {
  id            Int               @id @default(autoincrement())
  orderNumber   String            @unique @map("order_number")
  buyerId       Int               @map("buyer_id")
  buyer         Buyer             @relation("BuyerOrders", fields: [buyerId], references: [id])
  totalAmount   Float             @map("total_amount")
  paymentMethod String?           @map("payment_method")
  paymentStatus String            @default("PENDING") @map("payment_status")
  status        String            @default("CREATED")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  items         MasterOrderItem[]
  pickupOrders  PickupOrder[]
  dropOrders    DropOrder[]

  @@index([buyerId])
  @@index([status])
  @@map("master_orders")
}

model MasterOrderItem {
  id            Int         @id @default(autoincrement())
  masterOrderId Int         @map("master_order_id")
  masterOrder   MasterOrder @relation(fields: [masterOrderId], references: [id])
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  sellerId      Int         @map("seller_id")
  seller        Seller      @relation(fields: [sellerId], references: [id])
  quantity      Int
  price         Float

  @@index([masterOrderId])
  @@index([productId])
  @@index([sellerId])
  @@map("master_order_items")
}

model PickupOrder {
  id                 Int               @id @default(autoincrement())
  pickupOrderNumber  String?           @unique @map("pickup_order_number")
  masterOrderId      Int               @map("master_order_id")
  masterOrder        MasterOrder       @relation(fields: [masterOrderId], references: [id])
  sellerId           Int               @map("seller_id")
  seller             Seller            @relation(fields: [sellerId], references: [id])
  shgId              Int?              @map("shg_id")
  shg                User?             @relation("ShgPickupOrders", fields: [shgId], references: [id])
  transporterId      Int?              @map("transporter_id")
  transporter        User?             @relation("TransporterPickupOrders", fields: [transporterId], references: [id])
  status             String            @default("PENDING")
  pickupTime         DateTime?         @map("pickup_time")
  handoverCode       String?           @map("handover_code")
  createdAt          DateTime          @default(now()) @map("created_at")

  items              PickupOrderItem[]
  tracking           PickupTracking[]

  @@index([masterOrderId])
  @@index([sellerId])
  @@index([shgId])
  @@index([transporterId])
  @@index([status])
  @@map("pickup_orders")
}

model PickupOrderItem {
  id            Int         @id @default(autoincrement())
  pickupOrderId Int         @map("pickup_order_id")
  pickupOrder   PickupOrder @relation(fields: [pickupOrderId], references: [id])
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int

  verificationCode String?   @map("verification_code")
  generatedTime    DateTime? @map("generated_time")
  verifiedTime     DateTime? @map("verified_time")
  verificationStatus String?  @default("PENDING") @map("verification_status")

  @@index([pickupOrderId])
  @@index([productId])
  @@map("pickup_order_items")
}

model Warehouse {
  id        Int                  @id @default(autoincrement())
  name      String?
  address   String?
  inventory WarehouseInventory[]

  @@map("warehouses")
}

model WarehouseInventory {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int?
  qcStatus    String?   @map("qc_status")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_inventory")
}

model DropOrder {
  id              Int             @id @default(autoincrement())
  dropOrderNumber String?         @unique @map("drop_order_number")
  masterOrderId   Int             @map("master_order_id")
  masterOrder     MasterOrder     @relation(fields: [masterOrderId], references: [id])
  buyerId         Int             @map("buyer_id")
  buyer           Buyer           @relation(fields: [buyerId], references: [id])
  shgId           Int?            @map("shg_id")
  shg             User?           @relation("ShgDropOrders", fields: [shgId], references: [id])
  transporterId   Int?            @map("transporter_id")
  transporter     User?           @relation("TransporterDropOrders", fields: [transporterId], references: [id])
  status          String          @default("PENDING")
  deliveryAddress String?         @map("delivery_address")
  handoverCode    String?         @map("handover_code")
  createdAt       DateTime        @default(now()) @map("created_at")

  items           DropOrderItem[]
  tracking        DropTracking[]

  @@index([masterOrderId])
  @@index([buyerId])
  @@index([shgId])
  @@index([transporterId])
  @@index([status])
  @@map("drop_orders")
}

model DropOrderItem {
  id          Int       @id @default(autoincrement())
  dropOrderId Int       @map("drop_order_id")
  dropOrder   DropOrder @relation(fields: [dropOrderId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int?

  verificationCode String?   @map("verification_code")
  generatedTime    DateTime? @map("generated_time")
  verifiedTime     DateTime? @map("verified_time")
  verificationStatus String?  @default("PENDING") @map("verification_status")

  @@index([dropOrderId])
  @@index([productId])
  @@map("drop_order_items")
}

model PickupTracking {
  id            Int         @id @default(autoincrement())
  pickupOrderId Int         @map("pickup_order_id")
  pickupOrder   PickupOrder @relation(fields: [pickupOrderId], references: [id])
  status        String?
  remarks       String?
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")

  @@index([pickupOrderId])
  @@map("pickup_tracking")
}

model DropTracking {
  id          Int       @id @default(autoincrement())
  dropOrderId Int       @map("drop_order_id")
  dropOrder   DropOrder @relation(fields: [dropOrderId], references: [id])
  status      String?
  remarks     String?
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")

  @@index([dropOrderId])
  @@map("drop_tracking")
}

model PincodeDirectory {
  id             Int      @id @default(autoincrement())
  village        String
  postOffice     String
  pincode        String
  taluka         String
  district       String
  state          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([village])
  @@index([pincode])
  @@index([district])
  @@index([taluka])
  @@index([village, pincode])
  @@map("pincode_directory")
}

model Seller {
  id           Int      @id @default(autoincrement())
  sellerCode   String   @unique @map("seller_code")
  sellerName   String   @map("seller_name")
  mobileNumber String   @map("mobile_number")
  email        String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  village      String
  taluka       String
  district     String
  state        String   @default("Maharashtra")
  pincode      String
  postOffice   String?  @map("post_office")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  masterOrderItems  MasterOrderItem[]
  pickupOrders      PickupOrder[]
  orders            Order[]

  @@map("sellers")
}

model Buyer {
  id           Int      @id @default(autoincrement())
  buyerCode    String   @unique @map("buyer_code")
  buyerName    String   @map("buyer_name")
  mobileNumber String   @map("mobile_number")
  email        String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  village      String
  taluka       String
  district     String
  state        String   @default("Maharashtra")
  pincode      String
  postOffice   String?  @map("post_office")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  masterOrders     MasterOrder[]     @relation("BuyerOrders")
  dropOrders       DropOrder[]
  orders           Order[]

  @@map("buyers")
}

model VerificationRecord {
  id               Int       @id @default(autoincrement())
  orderId          String
  orderItemId      Int?
  pickupOrderId    Int?
  dropOrderId      Int?
  verificationType String
  senderId         Int?
  receiverId       Int?
  generatedCode    String
  status           String    @default("PENDING")
  generatedTime    DateTime? @default(now())
  verifiedTime     DateTime?
  expiryTime       DateTime?
  generatedBy      Int?
  verifiedBy       Int?
  attemptCount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("VerificationRecord")
}

model ScanHistory {
  id           Int       @id @default(autoincrement())
  orderId      String
  barcode      String
  scanType     String
  scanLocation String?
  scannedBy    Int?
  userRole     String?
  scanResult   String
  device       String?
  timestamp    DateTime  @default(now())

  @@map("ScanHistory")
}

model Parcel {
  parcelId           String   @id @default(uuid())
  orderId            String
  productId          Int
  productName        String
  parcelNumber       Int
  totalParcels       Int
  quantity           Int
  weight             String
  flowType           String
  parcelStatus       String
  currentHolderId    String?
  currentHolderType  String?
  verificationToken  String
  qrCodeValue        String
  qrImage            String   @db.Text
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  scanHistories      ParcelScanHistory[]
  scanSessionItems   ScanSessionItem[]

  @@map("Parcel")
}

model ParcelScanHistory {
  id            String   @id @default(uuid())
  parcelId      String
  parcel        Parcel   @relation(fields: [parcelId], references: [parcelId], onDelete: Cascade)
  orderId       String
  productId     Int
  productName   String
  userRole      String?
  userId        String?
  action        String
  currentHolder String?
  currentStage  String?
  scanResult    String
  scanTime      DateTime @default(now())
  remarks       String?
  latitude      Float?
  longitude     Float?

  @@map("ParcelScanHistory")
}

model ScanSession {
  sessionId   String            @id @default(uuid())
  userId      String
  userRole    String
  sessionType String            // "PICKUP" or "DROP"
  status      String            // "IN_PROGRESS" or "CONFIRMED" or "CANCELLED"
  orderIds    String            // Comma-separated order numbers/IDs
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       ScanSessionItem[]

  @@map("ScanSession")
}

model ScanSessionItem {
  id          String      @id @default(uuid())
  sessionId   String
  session     ScanSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  parcelId    String
  parcel      Parcel      @relation(fields: [parcelId], references: [parcelId], onDelete: Cascade)
  scannedAt   DateTime    @default(now())

  @@unique([sessionId, parcelId])
  @@map("ScanSessionItem")
}

model CommunityMember {
  id            String   @id @default(uuid())
  memberCode    String?  @unique
  type          String   // SHG, INDIVIDUAL
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  approvedAt    DateTime?
  rejectedAt    DateTime?

  // Personal Details
  profilePhoto      String?
  fullName          String
  mobileNumber      String
  age               Int?
  occupation        String?

  // SHG Details
  roleInShg         String?
  shgName           String?
  crpName           String?
  crpMobile         String?
  crpEmail          String?
  leaderName        String?
  leaderMobile      String?
  groupSize         Int?
  activeSince       String?

  // Business Details
  producesProducts  Boolean? @default(false)
  businessTeamSize  Int?
  productName       String?
  productCategory   String?
  dailyProduction   Float?
  weeklyProduction  Float?
  productionUnit    String?
  pricePerUnit      Float?

  // Address Details
  houseNo           String?
  deliveryAddress   String?
  village           String?
  taluka            String?
  district          String?
  state             String?
  pincode           String?

  // Document Details
  aadhaarNumber     String?
  panNumber         String?
  aadhaarFrontPhoto String?
  aadhaarBackPhoto  String?
  panCardPhoto      String?

  // Bank Details
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?
  bankName          String?
  branchName        String?
  upiId             String?

  // Storage Details
  storageSpace      String?
  storageWidth      Float?
  storageHeight     Float?
  storageDescription String?

  // Vehicle Details
  vehicleAvailable          Boolean? @default(false)
  vehicleType               String?
  vehicleRegistrationNumber String?
  drivingLicenseNumber      String?
  drivingLicensePhoto       String?
  vehiclePhoto              String?
}

model TransporterMember {
  id              String   @id @default(uuid())
  transporterCode String?  @unique
  type            String   // ROUTE_PARTNER, PERSONAL
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?

  // Personal Details
  profilePhoto    String?
  firstName       String
  lastName        String
  mobileNumber    String
  email           String?

  // Address Details
  residentialAddress String?
  village            String?
  taluka             String?
  district           String?
  state              String?
  pincode            String?

  // Driving Details
  licenseNumber      String?
  licensePhoto       String?
  licenseExpiryDate  DateTime?
  experienceYears    Int?

  // Bank Details
  accountHolderName  String?
  accountNumber      String?
  ifscCode           String?
  bankName           String?
  branchName         String?
  upiId              String?

  // Vehicle Details
  vehicleCategory       String?
  vehicleType           String?
  vehicleMake           String?
  vehicleNumber         String?
  vehicleRcPhoto        String?
  vehicleInsurancePhoto String?

  // Route Details
  assignedPincodes   Json?
  assignedVillages   Json?
  morningShift       String?
  eveningShift       String?
  workingDays        Json?

  // Milk Organization Details
  milkOrganizationName String?
  milkCenterName       String?
}
