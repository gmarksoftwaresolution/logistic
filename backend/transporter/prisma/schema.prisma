generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  SHG
  INDIVIDUAL
  TRANSPORTER
  ADMIN
  SUPER_ADMIN
  BUYER
  SELLER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
  COMPLETED
}

enum VehicleType {
  TWO_WHEELER
  THREE_WHEELER
  FOUR_WHEELER
  MILK_VAN
  OTHER
}

enum ProductCategory {
  FOOD
  HANDMADE
  AGRICULTURE
  TEXTILE
  DAIRY
  OTHER
}

enum StepStatus {
  PENDING
  COMPLETED
}

enum ShgRole {
  CRP
  LEADER
  MEMBER
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id                  Int       @id @default(autoincrement())

  // Supabase Auth ID
  authId              String    @unique @db.Uuid

  role                UserRole
  phoneNumber         String    @unique
  email               String?   @unique

  fullName            String?
  profilePhoto        String?

  language            String?   @default("English")

  isVerified          Boolean   @default(false)

  currentStep         Int       @default(0)
  profileCompletion   Int       @default(0)

  applicationStatus   ApplicationStatus @default(PENDING)

  uniqueCode          String?   @unique

  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  address             Address?
  bankDetails         BankDetail[]
  documents           Document[]
  otherDetails        OtherDetails[]

  shgDetail           ShgDetail?
  businessDetail      BusinessDetail?
  products            Product[]

  transporterDetail   TransporterDetail?
  drivingDetail       DrivingDetail?
  routeDetail         RouteDetail?
  milkVanDetail       MilkVanDetail?

  applications        Application[]
  stepTracking        StepTracking[]
  auditLogs           AuditLog[]

  // New clean architecture relations
  shgPickupOrders     PickupOrder[]       @relation("ShgPickupOrders")
  transporterPickups  PickupOrder[]       @relation("TransporterPickupOrders")
  
  shgDropOrders       DropOrder[]         @relation("ShgDropOrders")
  transporterDrops    DropOrder[]         @relation("TransporterDropOrders")

  @@index([phoneNumber])
  @@index([role])
}

//////////////////////////////////////////////////////
// COMMON TABLES
//////////////////////////////////////////////////////

model Address {
  id            Int      @id @default(autoincrement())

  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])

  houseNo       String
  deliveryAddress String?

  village       String?
  taluka        String?
  district      String
  state         String
  pincode       String

  landmark      String?

  latitude      Float?
  longitude     Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankDetail {
  id                  Int      @id @default(autoincrement())

  userId              Int
  user                User     @relation(fields: [userId], references: [id])

  accountHolderName   String
  bankName            String
  accountNumber       String
  ifscCode            String

  branchName          String?
  upiId               String?

  isVerified          Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([userId])
}

model Document {
  id                  Int      @id @default(autoincrement())

  userId              Int
  user                User     @relation(fields: [userId], references: [id])

  aadhaarNumber       String?
  panNumber           String?

  aadhaarFrontUrl     String?
  aadhaarBackUrl      String?
  panCardUrl          String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model OtherDetails {
  id                    Int         @id @default(autoincrement())

  userId                Int
  user                  User        @relation(fields: [userId], references: [id])

  vehicleType           String

  vehicleName           String?
  registrationNumber    String?
  licenseNumber         String?

  rcUrl                 String?
  insuranceUrl          String?
  vehicleImageUrl       String?

  heihgt                Float?
  width                 Float?
  storageSpace          String?
  DLurl                 String?
  wheeler               String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@index([userId])
}

model Application {
  id                  Int                 @id @default(autoincrement())

  userId              Int
  user                User                @relation(fields: [userId], references: [id])

  status              ApplicationStatus   @default(PENDING)

  reviewedBy          String?
  rejectionReason     String?

  approvedAt          DateTime?
  rejectedAt          DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model StepTracking {
  id            Int         @id @default(autoincrement())

  userId        Int
  user          User        @relation(fields: [userId], references: [id])

  step          Int
  status        StepStatus  @default(PENDING)

  data          Json?

  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, step])
}

//////////////////////////////////////////////////////
// SHG MODULE
//////////////////////////////////////////////////////

model ShgDetail {
  id                  Int         @id @default(autoincrement())

  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])

  fullName            String?
  shgName             String?
  shgLeaderName       String?
  shgLeaderContact    String?

  shgRole             ShgRole?

  crpName             String?
  crpMobile           String?
  crpEmail            String?

  groupSize           Int?
  imgUrl              String?
  age                 Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BusinessDetail {
  id                  Int         @id @default(autoincrement())

  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])

  producesProduct     Boolean     @default(false)
  businessTeamSize    Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

//////////////////////////////////////////////////////
// TRANSPORTER MODULE
//////////////////////////////////////////////////////

model TransporterDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  transporterCode       String?     @unique

  vehicleCategory       VehicleType?

  experienceYears       Int?

  availableFullTime     Boolean     @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DrivingDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  licenseNumber         String
  expiryDate            DateTime

  drivingExperience     Int?
  drivingLicenseNo      String?
  drivingLicenseUrl     String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model RouteDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  operatingArea         String

  pickupLocations       Json?
  dropLocations         Json?

  workingDays           Json?
  workingSchedule       Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MilkVanDetail {
  id                    Int         @id @default(autoincrement())

  userId                Int         @unique
  user                  User        @relation(fields: [userId], references: [id])

  sangathanName         String
  centerName            String

  assignedVillages      Json?

  morningShiftTime      String?
  eveningShiftTime      String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

//////////////////////////////////////////////////////
// AUDIT LOGS
//////////////////////////////////////////////////////

model AuditLog {
  id              Int      @id @default(autoincrement())

  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])

  module          String
  action          String

  oldData         Json?
  newData         Json?

  ipAddress       String?

  createdAt       DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// OTP
//////////////////////////////////////////////////////

model OTPVerification {
  id              Int      @id @default(autoincrement())

  phoneNumber     String

  otp             String
  type            String

  attempts        Int      @default(0)

  expiresAt       DateTime

  createdAt       DateTime @default(now())

  @@index([phoneNumber])
}



//////////////////////////////////////////////////////
// NEW CLEAN ARCHITECTURE MODELS
//////////////////////////////////////////////////////

model Product {
  id          Int      @id @default(autoincrement())
  sellerId    Int      @map("seller_id")
  seller      User     @relation(fields: [sellerId], references: [id])
  name        String
  category    String?
  price       Float
  stock       Int      @default(0)
  weight      Float?
  image       String?
  dailyProduction  Float?
  Unit             String?
  weeklyProduction Float?
  createdAt   DateTime @default(now()) @map("created_at")

  masterOrderItems   MasterOrderItem[]
  pickupOrderItems   PickupOrderItem[]
  warehouseInventory WarehouseInventory[]
  dropOrderItems     DropOrderItem[]

  @@index([sellerId])
  @@index([category])
  @@map("products")
}

model MasterOrder {
  id            Int               @id @default(autoincrement())
  orderNumber   String            @unique @map("order_number")
  buyerId       Int               @map("buyer_id")
  buyer         Buyer             @relation("BuyerOrders", fields: [buyerId], references: [id])
  totalAmount   Float             @map("total_amount")
  paymentMethod String?           @map("payment_method")
  paymentStatus String            @default("PENDING") @map("payment_status")
  status        String            @default("CREATED")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  items         MasterOrderItem[]
  pickupOrders  PickupOrder[]
  dropOrders    DropOrder[]

  @@index([buyerId])
  @@index([status])
  @@map("master_orders")
}

model MasterOrderItem {
  id            Int         @id @default(autoincrement())
  masterOrderId Int         @map("master_order_id")
  masterOrder   MasterOrder @relation(fields: [masterOrderId], references: [id])
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  sellerId      Int         @map("seller_id")
  seller        Seller      @relation(fields: [sellerId], references: [id])
  quantity      Int
  price         Float

  @@index([masterOrderId])
  @@index([productId])
  @@index([sellerId])
  @@map("master_order_items")
}

model PickupOrder {
  id                 Int               @id @default(autoincrement())
  pickupOrderNumber  String?           @unique @map("pickup_order_number")
  masterOrderId      Int               @map("master_order_id")
  masterOrder        MasterOrder       @relation(fields: [masterOrderId], references: [id])
  sellerId           Int               @map("seller_id")
  seller             Seller            @relation(fields: [sellerId], references: [id])
  shgId              Int?              @map("shg_id")
  shg                User?             @relation("ShgPickupOrders", fields: [shgId], references: [id])
  transporterId      Int?              @map("transporter_id")
  transporter        User?             @relation("TransporterPickupOrders", fields: [transporterId], references: [id])
  status             String            @default("PENDING")
  pickupTime         DateTime?         @map("pickup_time")
  handoverCode       String?           @map("handover_code")
  createdAt          DateTime          @default(now()) @map("created_at")

  items              PickupOrderItem[]
  tracking           PickupTracking[]

  @@index([masterOrderId])
  @@index([sellerId])
  @@index([shgId])
  @@index([transporterId])
  @@index([status])
  @@map("pickup_orders")
}

model PickupOrderItem {
  id            Int         @id @default(autoincrement())
  pickupOrderId Int         @map("pickup_order_id")
  pickupOrder   PickupOrder @relation(fields: [pickupOrderId], references: [id])
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int

  verificationCode String?   @map("verification_code")
  generatedTime    DateTime? @map("generated_time")
  verifiedTime     DateTime? @map("verified_time")
  verificationStatus String?  @default("PENDING") @map("verification_status")

  @@index([pickupOrderId])
  @@index([productId])
  @@map("pickup_order_items")
}

model Warehouse {
  id        Int                  @id @default(autoincrement())
  name      String?
  address   String?
  inventory WarehouseInventory[]

  @@map("warehouses")
}

model WarehouseInventory {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int?
  qcStatus    String?   @map("qc_status")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_inventory")
}

model DropOrder {
  id              Int             @id @default(autoincrement())
  dropOrderNumber String?         @unique @map("drop_order_number")
  masterOrderId   Int             @map("master_order_id")
  masterOrder     MasterOrder     @relation(fields: [masterOrderId], references: [id])
  buyerId         Int             @map("buyer_id")
  buyer           Buyer           @relation(fields: [buyerId], references: [id])
  shgId           Int?            @map("shg_id")
  shg             User?           @relation("ShgDropOrders", fields: [shgId], references: [id])
  transporterId   Int?            @map("transporter_id")
  transporter     User?           @relation("TransporterDropOrders", fields: [transporterId], references: [id])
  status          String          @default("PENDING")
  deliveryAddress String?         @map("delivery_address")
  handoverCode    String?         @map("handover_code")
  createdAt       DateTime        @default(now()) @map("created_at")

  items           DropOrderItem[]
  tracking        DropTracking[]

  @@index([masterOrderId])
  @@index([buyerId])
  @@index([shgId])
  @@index([transporterId])
  @@index([status])
  @@map("drop_orders")
}

model DropOrderItem {
  id          Int       @id @default(autoincrement())
  dropOrderId Int       @map("drop_order_id")
  dropOrder   DropOrder @relation(fields: [dropOrderId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int?

  verificationCode String?   @map("verification_code")
  generatedTime    DateTime? @map("generated_time")
  verifiedTime     DateTime? @map("verified_time")
  verificationStatus String?  @default("PENDING") @map("verification_status")

  @@index([dropOrderId])
  @@index([productId])
  @@map("drop_order_items")
}

model PickupTracking {
  id            Int         @id @default(autoincrement())
  pickupOrderId Int         @map("pickup_order_id")
  pickupOrder   PickupOrder @relation(fields: [pickupOrderId], references: [id])
  status        String?
  remarks       String?
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")

  @@index([pickupOrderId])
  @@map("pickup_tracking")
}

model DropTracking {
  id          Int       @id @default(autoincrement())
  dropOrderId Int       @map("drop_order_id")
  dropOrder   DropOrder @relation(fields: [dropOrderId], references: [id])
  status      String?
  remarks     String?
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([dropOrderId])
  @@map("drop_tracking")
}

model Pincode {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  branchType     String?
  deliveryStatus String?
  circle         String?
  district       String?
  division       String?
  region         String?
  block          String?
  state          String?
  country        String?
  pincode        String

  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([pincode, name])
  @@index([pincode])
  @@map("pincodes")
}

model PincodeDirectory {
  id        Int      @id @default(autoincrement())
  pincode   String
  village   String
  taluka    String
  district  String
  state     String
  country   String   @default("India")

  @@index([pincode])
  @@map("pincode_directory")
}

model Seller {
  id           Int      @id @default(autoincrement())
  sellerCode   String   @unique @map("seller_code")
  sellerName   String   @map("seller_name")
  mobileNumber String   @map("mobile_number")
  email        String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  village      String
  taluka       String
  district     String
  state        String
  pincode      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  masterOrderItems  MasterOrderItem[]
  pickupOrders      PickupOrder[]

  @@map("sellers")
}

model Buyer {
  id           Int      @id @default(autoincrement())
  buyerCode    String   @unique @map("buyer_code")
  buyerName    String   @map("buyer_name")
  mobileNumber String   @map("mobile_number")
  email        String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  village      String
  taluka       String
  district     String
  state        String
  pincode      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  masterOrders     MasterOrder[]     @relation("BuyerOrders")
  dropOrders       DropOrder[]

  @@map("buyers")
}

model VerificationRecord {
  id               Int       @id @default(autoincrement())
  orderId          String
  orderItemId      Int?
  pickupOrderId    Int?
  dropOrderId      Int?
  verificationType String
  senderId         Int?
  receiverId       Int?
  generatedCode    String
  status           String    @default("PENDING")
  generatedTime    DateTime? @default(now())
  verifiedTime     DateTime?
  expiryTime       DateTime?
  generatedBy      Int?
  verifiedBy       Int?
  attemptCount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("VerificationRecord")
}

model BarcodeRecord {
  id           Int       @id @default(autoincrement())
  orderId      String
  pickupOrderId Int?
  dropOrderId   Int?
  inventoryId   Int?
  barcodeValue String    @unique
  barcodeType  String
  status       String    @default("GENERATED")
  generatedTime DateTime? @default(now())
  printedTime  DateTime?
  scannedTime  DateTime?
  dispatchTime DateTime?
  intakeTime   DateTime?
  returnType   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("BarcodeRecord")
}

model ScanHistory {
  id           Int       @id @default(autoincrement())
  orderId      String
  barcode      String
  scanType     String
  scanLocation String?
  scannedBy    Int?
  userRole     String?
  scanResult   String
  device       String?
  timestamp    DateTime  @default(now())

  @@map("ScanHistory")
}




