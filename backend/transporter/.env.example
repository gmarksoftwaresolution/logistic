# Transporter Backend Server Configuration
PORT=3001

# Database Configuration (Shared PostgreSQL Instance)
# Replace with your actual Postgres connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logistic_db?schema=public"

# JWT Token Secrets (Change these in production to secure keys)
JWT_SECRET="transporter-backend-super-secret-key-change-me"
JWT_REFRESH_SECRET="transporter-backend-super-refresh-secret-key-change-me"
