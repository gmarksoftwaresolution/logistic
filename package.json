{
  "name": "logistic-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Logistic Monorepo Platform",
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "shg-app:start": "npm start --workspace=@logistic/shg-app",
    "transporter-app:start": "npm start --workspace=@logistic/transporter-app",
    "shg-backend:dev": "npm run start:dev --workspace=@logistic/shg-backend",
    "transporter-backend:dev": "npm run start:dev --workspace=@logistic/transporter-backend"
  }
}
