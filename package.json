{
  "name": "logistic-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Logistic Monorepo Platform",
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "shg-app:start": "node scripts/update-ip.js && npm start --workspace=@logistic/shg-app",
    "transporter-app:start": "node scripts/update-ip.js && npm start --workspace=@logistic/transporter-app",
    "shg-backend:dev": "npm run start:dev --workspace=@logistic/shg-backend",
    "transporter-backend:dev": "npm run start:dev --workspace=@logistic/transporter-backend",
    "gmu-backend:dev": "npm run start:dev --workspace=@logistic/gmu-backend",
    "db:generate": "npm run prisma:generate --workspace=@logistic/db",
    "db:push": "npm run prisma:migrate --workspace=@logistic/db"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "react-refresh": "^0.18.0"
  }
}
