{
  "expo": {
    "name": "Transporter Logistic",
    "slug": "transporter-app-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/app_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/GMLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/app_icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gmarksoft.transporter",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./src/assets/app_icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "f26915eb-cb39-4b59-a21a-3ded3e88e0d3"
      }
    },
    "owner": "mahendra7649"
  }
}
