{
  "expo": {
    "name": "Delivery Partner App",
    "slug": "shg-logistics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/GMU Logo Splash.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/GMU Logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gmu.app",
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/GMU Logo.png",
          "resizeMode": "contain"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-localization",
      "expo-font"
    ],
    "owner": "mahadev8484",
    "extra": {
      "eas": {
        "projectId": "3442c592-21e1-487b-a86e-ba8e5d7a8933"
      }
    }
  }
}
